{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Batch Control (main.py)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "PYTHONDONTWRITEBYTECODE": "1"
      }
    },
    {
      "name": "Batch Control (módulo src.gui.app)",
      "type": "debugpy",
      "request": "launch",
      "module": "src.gui.app",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "PYTHONDONTWRITEBYTECODE": "1"
      }
    }
  ]
}
